{
  "manifest_version": 3,
  "name": "Enhanced Shogun",
  "version": "1.2",
  "description": "Extensión para el envío de reportes de batallas y espionajes de ShogunsReturn a Discord.",
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://discord.com/api/webhooks/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://shogunsreturn.com/*"
      ],
      "js": [
        "shared.js",
        "spies.js",
        "battles.js",
        "main.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/copyToClipboard16.png",
        "images/download16.png"
      ],
      "matches": [
        "https://shogunsreturn.com/*"
      ]
    }
  ],
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  }
}